<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · Venza Care UK Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" type="image/png" href="/images/logo.png" />
</head>
<body class="admin-body page">
  <header class="admin-topbar">
    <div class="admin-topbar__inner">
      <a href="/admin" class="brand" style="gap:0.6rem;color:#fff;">
        <img src="/images/logo-white.png" alt="Venza Care" class="admin-logo" />
        <span style="font-weight:400;opacity:.7;font-family:var(--font-body);font-size:.8rem;">Backoffice</span>
      </a>
      <nav style="display:flex;gap:1.3rem;align-items:center;margin-left:1.5rem;">
        <a href="/admin" class="<%= currentPath === '/admin' ? 'is-active' : '' %>">Dashboard</a>
        <a href="/admin/jobs/new" class="<%= currentPath === '/admin/jobs/new' ? 'is-active' : '' %>">Post a job</a>
        <a href="/admin/applications" class="<%= currentPath.startsWith('/admin/applications') ? 'is-active' : '' %>">Applications</a>
        <a href="/admin/messages" class="<%= currentPath === '/admin/messages' ? 'is-active' : '' %>">Enquiries</a>
      </nav>
      <div class="spacer"></div>
      <a href="/" target="_blank" rel="noopener" style="font-size:.88rem;">View site ↗</a>
      <form action="/admin/logout" method="post" class="inline-form">
        <button type="submit" class="btn btn--sm" style="background:rgba(255,255,255,.15);color:#fff;">Sign out</button>
      </form>
    </div>
  </header>
  <main class="admin-main">
